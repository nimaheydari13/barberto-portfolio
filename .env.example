# Appwrite Configuration
# Copy this file to .env and fill in your actual values

PROJECT_ID=your_project_id_here
ENDPOINT=https://cloud.appwrite.io/v1
STORAGE_BUCKET_ID=your_storage_bucket_id
DATABASE_ID=your_database_id

# Collections
COLLECTION_USERS=your_users_collection_id
COLLECTION_BARBERS=your_barbers_collection_id
COLLECTION_BARBERS_INFO=your_barbers_info_collection_id
COLLECTION_STORE_ITEMS=your_store_items_collection_id
COLLECTION_SUGGESTIONS=your_suggestions_collection_id
COLLECTION_VERSION_CHECKER=your_version_checker_collection_id
COLLECTION_APP_CONSTANTS=your_app_constants_collection_id
COLLECTION_CONTENTS=your_contents_collection_id

# External Services
MAP_IR_TOKEN=your_map_ir_token
GOOGLE_MAPS_API_KEY=your_google_maps_key
